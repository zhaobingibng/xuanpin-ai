# Application
APP_NAME=xuanpin-ai
APP_ENV=development
APP_DEBUG=true
APP_LOG_LEVEL=DEBUG

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=xuanpin_ai
DB_USER=postgres
DB_PASSWORD=your_password_here

# AI / LLM (OpenAI-compatible: DeepSeek / Qwen / GPT)
AI_API_KEY=your_api_key_here
AI_MODEL=deepseek-chat
AI_BASE_URL=https://api.deepseek.com

# Crawler
CRAWLER_USER_AGENT=XuanPinBot/1.0
CRAWLER_TIMEOUT=30
CRAWLER_MAX_RETRIES=3

# Storage
STORAGE_PATH=./storage

# Daily Pipeline
DAILY_CRAWL_HOUR=8
CRAWL_PLATFORMS=["xiaohongshu","taobao"]
